---
import Base from "../layouts/Base.astro";
import { loadWeekly, severityBadgeClass } from "../lib/data";

const weekly = await loadWeekly();
const hasFindings = (weekly?.findings?.length ?? 0) > 0;
const withBase = (path: string): string => {
  const base = import.meta.env.BASE_URL.replace(/\/$/, "");
  const normalized = path === "/" ? "/" : path.startsWith("/") ? path : `/${path}`;
  return `${base}${normalized}`;
};
---

<Base
  title="Weekly report | The Bus Factor"
  description="This week's continuity-risk findings, narrative, and share card."
  snapshotWeek={weekly?.headline.snapshot_week}
  methodologyVersion={weekly?.headline.methodology_version}
  activeNav="weekly"
>
  {
    !weekly ? (
      <div class="empty-state">
        <h1>Weekly report</h1>
        <p>Generate the pipeline export to populate this page.</p>
      </div>
    ) : (
      <article>
        <header class="weekly-header">
          <h1>{weekly.headline.headline}</h1>
          <p class="muted">{weekly.headline.summary}</p>
        </header>

        <section class="card share">
          <img
            src={withBase("/weekly/latest.png")}
            alt="Weekly share card summarising the top findings."
            width="1200"
            height="630"
            onerror="this.style.display='none'"
          />
          <p class="muted">
            Share card is regenerated by <code>generate_weekly_card</code> on every pipeline run.
          </p>
        </section>

        {hasFindings ? (
          <section aria-labelledby="findings-heading">
            <h2 id="findings-heading">Top findings</h2>
            <table>
              <thead>
                <tr>
                  <th scope="col">Rank</th>
                  <th scope="col">Package</th>
                  <th scope="col">Severity</th>
                  <th scope="col">Risk</th>
                  <th scope="col">Primary finding</th>
                </tr>
              </thead>
              <tbody>
                {weekly.findings.map((f) => (
                  <tr>
                    <td>#{f.rank}</td>
                    <td>
                      <a href={withBase(`/package/${f.slug}/`)}>
                        {f.ecosystem} · {f.package_name}
                      </a>
                    </td>
                    <td>
                      <span class={severityBadgeClass(f.severity_tier)}>{f.severity_tier}</span>
                    </td>
                    <td>{f.risk_score.toFixed(1)}</td>
                    <td class="muted">{f.primary_finding}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </section>
        ) : (
          <section aria-labelledby="zero-heading" class="card">
            <h2 id="zero-heading">Zero-flagged fallback</h2>
            <p>{weekly.zero_flagged_fallback_copy ?? "No packages crossed the flag threshold."}</p>
          </section>
        )}

        <section aria-labelledby="breakdown-heading">
          <h2 id="breakdown-heading">Ecosystem breakdown</h2>
          <ul class="breakdown">
            {Object.entries(weekly.headline.ecosystem_breakdown).map(([eco, count]) => (
              <li>
                <span class="muted">{eco}</span>
                <strong>{count}</strong>
              </li>
            ))}
          </ul>
        </section>
      </article>
    )
  }
</Base>

<style>
  .weekly-header {
    margin-bottom: 20px;
  }
  .share {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 24px;
  }
  .share img {
    display: block;
    max-width: 100%;
    width: 100%;
    height: auto;
    border-radius: 8px;
  }
  .breakdown {
    list-style: none;
    padding: 0;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .breakdown li {
    background: var(--surface);
    padding: 12px 18px;
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    min-width: 120px;
  }
  .breakdown strong {
    font-size: 20px;
  }
</style>
