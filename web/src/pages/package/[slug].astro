---
import Base from "../../layouts/Base.astro";
import { loadPackages, severityBadgeClass } from "../../lib/data";
import type { PackageDetail } from "../../lib/schemas";

export async function getStaticPaths() {
  const packages = await loadPackages();
  const entries = packages?.entries ?? [];
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry, snapshotWeek: packages?.snapshot_week, methodologyVersion: packages?.methodology_version },
  }));
}

const { entry, snapshotWeek, methodologyVersion } = Astro.props as {
  entry: PackageDetail;
  snapshotWeek: string | undefined;
  methodologyVersion: string | undefined;
};

const signalLabel: Record<string, string> = {
  release_recency: "Release recency",
  commit_recency: "Commit recency",
  release_cadence_decay: "Release cadence decay",
  issue_responsiveness: "Issue responsiveness",
  all_time_contribution_concentration: "Contributor concentration (all-time)",
  recent_commit_concentration_365d: "Contributor concentration (last 365d)",
  openssf_scorecard: "OpenSSF Scorecard",
};

const badges: string[] = [];
if (entry.flagged) badges.push("Flagged");
if (entry.exclusion_reason) badges.push(entry.exclusion_reason.replaceAll("_", " "));

const withBase = (path: string): string => {
  const base = import.meta.env.BASE_URL.replace(/\/$/, "");
  const normalized = path === "/" ? "/" : path.startsWith("/") ? path : `/${path}`;
  return `${base}${normalized}`;
};
---

<Base
  title={`${entry.package_name} · ${entry.ecosystem} · The Bus Factor`}
  description={`Continuity-risk snapshot for ${entry.package_name} on ${entry.ecosystem}.`}
  snapshotWeek={snapshotWeek}
  methodologyVersion={methodologyVersion}
  activeNav="home"
>
  <nav aria-label="Breadcrumb" class="breadcrumb">
    <a href={withBase("/")}>Leaderboard</a> / <span>{entry.ecosystem}</span> /
    <strong>{entry.package_name}</strong>
  </nav>

  <header class="detail-header">
    <div>
      <h1>{entry.package_name}</h1>
      <p class="muted">
        {entry.ecosystem.toUpperCase()} · mapping confidence{" "}
        <strong>{entry.mapping_confidence.bucket}</strong> ({entry.mapping_confidence.points} pts)
      </p>
      <div class="tags">
        <span class={severityBadgeClass(entry.severity_tier)}>{entry.severity_tier}</span>
        {badges.map((b) => <span class="badge badge--watch">{b}</span>)}
      </div>
    </div>
    <div class="scores">
      <div class="score">
        <span class="muted">Risk</span>
        <strong>{entry.risk_score.toFixed(1)}</strong>
      </div>
      <div class="score">
        <span class="muted">Importance</span>
        <strong>{entry.importance_score.toFixed(1)}</strong>
      </div>
      <div class="score">
        <span class="muted">Fragility</span>
        <strong>{entry.fragility_score.toFixed(1)}</strong>
      </div>
      <div class="score">
        <span class="muted">Confidence</span>
        <strong>{entry.confidence}</strong>
      </div>
    </div>
  </header>

  <section aria-labelledby="evidence-heading">
    <h2 id="evidence-heading">Fragility evidence</h2>
    {
      entry.fragility_signals.length === 0 ? (
        <p class="muted">No fragility signals captured for this package.</p>
      ) : (
        <div class="grid">
          {entry.fragility_signals.map((signal) => (
            <article class="card">
              <h3>{signalLabel[signal.name] ?? signal.name}</h3>
              <div class="meter" aria-hidden="true">
                <span style={`--fill:${Math.min(100, Math.max(0, signal.contribution))}%`}></span>
              </div>
              <p class="muted contrib">
                Contribution: <strong>{signal.contribution.toFixed(1)}</strong> / 100
              </p>
              <p>{signal.evidence}</p>
            </article>
          ))}
        </div>
      )
    }
  </section>

  <section aria-labelledby="mapping-heading">
    <h2 id="mapping-heading">Repository mapping</h2>
    <dl class="kv">
      <dt>Repository</dt>
      <dd>
        {entry.repository_url ? (
          <a href={entry.repository_url} rel="noreferrer">
            {entry.repository_url}
          </a>
        ) : (
          <span class="muted">Not mappable with confidence</span>
        )}
      </dd>
      <dt>Registry</dt>
      <dd>
        {entry.registry_url ? (
          <a href={entry.registry_url} rel="noreferrer">
            {entry.registry_url}
          </a>
        ) : (
          <span class="muted">—</span>
        )}
      </dd>
      <dt>Confidence points</dt>
      <dd>
        {entry.mapping_confidence.points} pts ({entry.mapping_confidence.bucket})
      </dd>
      <dt>Rationale</dt>
      <dd>
        {entry.mapping_confidence.rationale.length > 0 ? (
          <ul class="rationale-list">
            {entry.mapping_confidence.rationale.map((r) => (
              <li>{r}</li>
            ))}
          </ul>
        ) : (
          <span class="muted">No contributing signals.</span>
        )}
      </dd>
    </dl>
  </section>

  <section aria-labelledby="timeline-heading">
    <h2 id="timeline-heading">Timeline</h2>
    <dl class="kv">
      <dt>First release</dt>
      <dd>{entry.first_release_date}</dd>
      <dt>Latest release</dt>
      <dd>{entry.latest_release_date}</dd>
      <dt>Last commit</dt>
      <dd>{entry.last_commit_date ?? "—"}</dd>
      <dt>Archived</dt>
      <dd>{entry.is_archived ? "Yes" : "No"}</dd>
      <dt>Deprecated</dt>
      <dd>{entry.is_deprecated ? "Yes" : "No"}</dd>
    </dl>
  </section>
</Base>

<style>
  .breadcrumb {
    margin-bottom: 8px;
    font-size: 13px;
    color: var(--text-muted);
  }
  .detail-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .tags {
    display: flex;
    gap: 8px;
    margin-top: 12px;
    flex-wrap: wrap;
  }
  .scores {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    background: var(--surface);
    padding: 16px;
    border-radius: var(--radius);
    min-width: 320px;
  }
  .score {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }
  .score strong {
    font-size: 24px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 16px;
  }
  .card h3 {
    margin: 0 0 8px;
    font-size: 16px;
  }
  .meter {
    width: 100%;
    height: 8px;
    background: var(--surface-2);
    border-radius: 999px;
    overflow: hidden;
  }
  .meter span {
    display: block;
    width: var(--fill, 0%);
    height: 100%;
    background: var(--accent);
  }
  .contrib {
    margin: 8px 0 10px;
    font-size: 13px;
  }
  .kv {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 8px 20px;
    background: var(--surface);
    padding: 16px;
    border-radius: var(--radius);
  }
  .kv dt {
    color: var(--text-muted);
    font-size: 13px;
    padding-top: 3px;
  }
  .kv dd {
    margin: 0;
  }
  .rationale-list {
    margin: 0;
    padding-left: 18px;
  }
</style>
